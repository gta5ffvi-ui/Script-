local player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

-- 🔑 KEY
local correctKey = "YT"
local unlocked = false
local attempts = 0

-- 📦 GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

-- 🔐 KEY UI
local keyFrame = Instance.new("Frame", gui)
keyFrame.Size = UDim2.new(0,300,0,170)
keyFrame.Position = UDim2.new(0.5,-150,0.5,-85)
keyFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)

local box = Instance.new("TextBox", keyFrame)
box.Size = UDim2.new(1,-20,0,40)
box.Position = UDim2.new(0,10,0,60)
box.PlaceholderText = "Enter Key..."

local status = Instance.new("TextLabel", keyFrame)
status.Size = UDim2.new(1,0,0,30)
status.Position = UDim2.new(0,0,0,120)
status.TextColor3 = Color3.new(1,0,0)
status.BackgroundTransparency = 1

-- 📋 MAIN MENU
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,420,0,520)
main.Position = UDim2.new(0.5,-210,1,0)
main.BackgroundColor3 = Color3.fromRGB(15,15,15)
main.Visible = false

-- 🧠 DRAG MENU
local dragging = false
local dragStart, startPos

main.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

UIS.InputEnded:Connect(function()
	dragging = false
end)

-- 🎬 ANIMATION
local function openMenu(state)
	local goal = {}

	if state then
		goal.Position = UDim2.new(0.5,-210,0.5,-260)
	else
		goal.Position = UDim2.new(0.5,-210,1,0)
	end

	TweenService:Create(main, TweenInfo.new(0.3), goal):Play()
end

-- 🔘 TOGGLE
local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0,140,0,45)
toggle.Position = UDim2.new(0,10,0,10)
toggle.Text = "MENU"

toggle.MouseButton1Click:Connect(function()
	if unlocked then
		main.Visible = not main.Visible
		openMenu(main.Visible)
	else
		keyFrame.Visible = true
	end
end)

-- ✔ KEY CHECK
box.FocusLost:Connect(function()
	if box.Text == correctKey then
		unlocked = true
		keyFrame:Destroy()
		main.Visible = true
		openMenu(true)
	else
		attempts += 1
		status.Text = "Wrong ❌"
		if attempts >= 3 then
			player:Kick("Too many wrong keys")
		end
	end
end)

-- 🧠 HUM
local function hum()
	local c = player.Character
	return c and c:FindFirstChildOfClass("Humanoid")
end

-- 🧱 BUILD SYSTEM (Minecraft Style)
local buildFolder = Instance.new("Folder", workspace)
buildFolder.Name = "Builds"

local mouse = player:GetMouse()
local buildMode = false

local function createWall(pos, normal)
	local p = Instance.new("Part")
	p.Size = Vector3.new(10,10,1)
	p.Anchored = true
	p.Color = Color3.fromRGB(0,255,255)
	p.Material = Enum.Material.SmoothPlastic
	p.CFrame = CFrame.new(pos,pos+normal)*CFrame.new(0,5,0)
	p.Parent = buildFolder
end

local function clearBuild()
	for _,v in pairs(buildFolder:GetChildren()) do
		v:Destroy()
	end
end

local function buildHouse()
	clearBuild()
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local p = root.Position

	for i=0,3 do
		createWall(p+Vector3.new(i*10,0,0),Vector3.new(0,0,-1))
		createWall(p+Vector3.new(i*10,0,30),Vector3.new(0,0,1))
	end

	for i=0,3 do
		createWall(p+Vector3.new(0,0,i*10),Vector3.new(1,0,0))
		createWall(p+Vector3.new(30,0,i*10),Vector3.new(-1,0,0))
	end
end

mouse.Button1Down:Connect(function()
	if buildMode then
		createWall(mouse.Hit.Position, mouse.Hit.Normal)
	end
end)

-- ✈️ FLY
local fly = false
local function toggleFly()
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	fly = not fly

	if fly then
		local bv = Instance.new("BodyVelocity", root)
		bv.MaxForce = Vector3.new(1,1,1)*100000

		task.spawn(function()
			while fly and bv.Parent do
				bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * 60
				task.wait()
			end
			bv:Destroy()
		end)
	end
end

-- 👻 NOCLIP
local noclip = false
game:GetService("RunService").Stepped:Connect(function()
	if noclip then
		local c = player.Character
		if c then
			for _,v in pairs(c:GetDescendants()) do
				if v:IsA("BasePart") then
					v.CanCollide = false
				end
			end
		end
	end
end)

-- 🧱 TABS SYSTEM
local tabFrame = Instance.new("Frame", main)
tabFrame.Size = UDim2.new(1,0,0,40)
tabFrame.BackgroundColor3 = Color3.fromRGB(20,20,20)

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1,-10,1,-50)
scroll.Position = UDim2.new(0,5,0,45)
scroll.CanvasSize = UDim2.new(0,0,0,0)
scroll.ScrollBarThickness = 6
scroll.BackgroundTransparency = 1

local layout = Instance.new("UIListLayout", scroll)

local function clearButtons()
	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end
end

local function addButton(text, func)
	local b = Instance.new("TextButton", scroll)
	b.Size = UDim2.new(1,0,0,40)
	b.Text = text
	b.BackgroundColor3 = Color3.fromRGB(30,30,30)
	b.TextColor3 = Color3.fromRGB(0,255,255)
	b.MouseButton1Click:Connect(func)
	task.wait()
	scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
end

-- 🎮 TABS
local function PlayerTab()
	clearButtons()

	addButton("🚀 SPEED", function()
		local h = hum()
		if h then h.WalkSpeed = 60 end
	end)

	addButton("🦘 JUMP", function()
		local h = hum()
		if h then h.JumpPower = 120 end
	end)

	addButton("✈️ FLY", toggleFly)
	addButton("👻 NOCLIP", function() noclip = not noclip end)
	addButton("🏠 SAFE SPAWN", function()
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		local sp = workspace:FindFirstChildOfClass("SpawnLocation")
		if root and sp then root.CFrame = sp.CFrame + Vector3.new(0,5,0) end
	end)
end

local function BuildTab()
	clearButtons()

	addButton("🧱 BUILD MODE", function()
		buildMode = not buildMode
	end)

	addButton("🏠 BUILD HOUSE", buildHouse)
	addButton("🧹 CLEAR", clearBuild)
end

-- 🔘 TAB BUTTONS
local function tabButton(name, func, x)
	local b = Instance.new("TextButton", tabFrame)
	b.Size = UDim2.new(0.5,0,1,0)
	b.Position = UDim2.new(x,0,0,0)
	b.Text = name
	b.TextColor3 = Color3.fromRGB(0,255,255)
	b.BackgroundColor3 = Color3.fromRGB(25,25,25)
	b.MouseButton1Click:Connect(func)
end

tabButton("PLAYER", PlayerTab, 0)
tabButton("BUILD", BuildTab, 0.5)

PlayerTab()
