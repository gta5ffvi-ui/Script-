-- 📋 TAB SYSTEM
------------------------------------------------
local tabBar = Instance.new("Frame", main)
tabBar.Size = UDim2.new(1,0,0.1,0)
tabBar.BackgroundColor3 = Color3.fromRGB(25,25,25)

local scroll = Instance.new("ScrollingFrame", main)
scroll.Size = UDim2.new(1,0,0.9,0)
scroll.Position = UDim2.new(0,0,0.1,0)
scroll.BackgroundTransparency = 1
scroll.ScrollBarThickness = 6

local layout = Instance.new("UIListLayout", scroll)

local function clear()
	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
end

local function button(name, func)
	local b = Instance.new("TextButton", scroll)
	b.Size = UDim2.new(1,0,0,45)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(30,30,30)
	b.TextColor3 = Color3.fromRGB(0,255,255)
	b.MouseButton1Click:Connect(func)

	task.wait()
	scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
end

------------------------------------------------
-- 🎮 TABS
------------------------------------------------
local function PlayerTab()
	clear()

	button("🚀 SPEED", function()
		local h = hum()
		if h then h.WalkSpeed = 60 end
	end)

	button("🦘 JUMP", function()
		local h = hum()
		if h then h.JumpPower = 120 end
	end)

	button("🧠 FIX MOVEMENT", function()
		resetMovement()
	end)
end

local function BuildTab()
	clear()

	button("🧱 BUILD MODE", function()
		buildMode = not buildMode
	end)

	button("🏠 AUTO HOUSE", autoHouse)
	button("🧹 CLEAR BUILD", clearBuild)
end

local function FunTab()
	clear()

	button("💥 RESET", function()
		local h = hum()
		if h then h.Health = 0 end
	end)
end

